msgid "Back"
msgstr "Voltar"

msgid "Next"
msgstr "Avançar"

msgid "Install"
msgstr "Instalar"

msgid "Open terminal"
msgstr "Abrir terminal"

msgid "Confirm installation"
msgstr "Confirmar instalação"

msgid "All data on the selected disk will be permanently erased and the system will be installed. This cannot be undone."
msgstr "Todos os dados do disco selecionado serão apagados permanentemente e o sistema será instalado. Isso não pode ser desfeito."

msgid "The staged partition changes will now be written to disk and Sirius will be installed. Formatted or deleted data cannot be recovered."
msgstr "As mudanças de partição agendadas serão gravadas no disco e o Sirius será instalado. Dados formatados ou excluídos não poderão ser recuperados."

msgid "Cancel"
msgstr "Cancelar"

msgid "Erase disk and install"
msgstr "Apagar disco e instalar"

msgid "Welcome"
msgstr "Bem-vindo"

msgid "This assistant will guide you through installation."
msgstr "Este assistente vai guiá-lo pela instalação."

msgid "Network"
msgstr "Rede"

msgid "Connect to a network. A connection is optional but recommended."
msgstr "Conecte-se a uma rede. A conexão é opcional, mas recomendada."

msgid "Choose a Wi-Fi network below."
msgstr "Escolha uma rede Wi-Fi abaixo."

msgid "Available Wi-Fi networks"
msgstr "Redes Wi-Fi disponíveis"

msgid "Looking for networks…"
msgstr "Procurando redes…"

msgid "Connect"
msgstr "Conectar"

msgid "Connected"
msgstr "Conectado"

msgid "Scan again"
msgstr "Procurar novamente"

msgid "Open network"
msgstr "Rede aberta"

msgid "WPA/WPA2 Personal"
msgstr "WPA/WPA2 pessoal"

msgid "WPA3 Personal"
msgstr "WPA3 pessoal"

msgid "Enterprise or legacy security is not supported here"
msgstr "Segurança enterprise ou legada não é suportada aqui"

msgid "Connect to {ssid}"
msgstr "Conectar a {ssid}"

msgid "Enter the Wi-Fi password."
msgstr "Digite a senha do Wi-Fi."

msgid "Keyboard layout"
msgstr "Layout do teclado"

msgid "Type here to test your layout"
msgstr "Digite aqui para testar o layout"

msgid "Time zone"
msgstr "Fuso horário"

msgid "Partitioning"
msgstr "Particionamento"

msgid "Automatic"
msgstr "Automático"

msgid "Encrypt the disk (LUKS)"
msgstr "Criptografar o disco (LUKS)"

msgid "Bind encryption to TPM"
msgstr "Vincular criptografia ao TPM"

msgid "Create your account"
msgstr "Crie sua conta"

msgid "Full name"
msgstr "Nome completo"

msgid "Username"
msgstr "Nome de usuário"

msgid "Password"
msgstr "Senha"

msgid "Confirm password"
msgstr "Confirmar senha"

msgid "Hostname"
msgstr "Nome da máquina"

msgid "Ready to install"
msgstr "Pronto para instalar"

msgid "Review your choices before writing changes to disk."
msgstr "Revise suas escolhas antes de gravar as mudanças no disco."

msgid "Language"
msgstr "Idioma"

msgid "Keyboard"
msgstr "Teclado"

msgid "Disk"
msgstr "Disco"

msgid "Encryption"
msgstr "Criptografia"

msgid "User"
msgstr "Usuário"

msgid "enabled"
msgstr "ativada"

msgid "disabled"
msgstr "desativada"

msgid "manual layout"
msgstr "layout manual"

msgid "Storage"
msgstr "Armazenamento"

msgid "Choose a disk and how Sirius should use it. Changes are applied only after confirmation."
msgstr "Escolha um disco e como o Sirius deve usá-lo. As mudanças só serão aplicadas após a confirmação."

msgid "Destination disk"
msgstr "Disco de destino"

msgid "Automatic partitioning"
msgstr "Particionamento automático"

msgid "Erase the disk and create the needed partitions automatically."
msgstr "Apagar o disco e criar as partições necessárias automaticamente."

msgid "Manual partitioning"
msgstr "Particionamento manual"

msgid "Create, resize, and delete partitions yourself."
msgstr "Crie, redimensione e exclua partições você mesmo."

msgid "All data on this disk will be erased."
msgstr "Todos os dados deste disco serão apagados."

msgid "Discard changes"
msgstr "Descartar alterações"

msgid "Disk layout"
msgstr "Mapa do disco"

msgid "Table"
msgstr "Tabela"

msgid "Partition editor"
msgstr "Editor de partições"

msgid "Close"
msgstr "Fechar"

msgid "Done"
msgstr "Concluído"

msgid "Delete Partition"
msgstr "Excluir Partição"

msgid "Not mounted"
msgstr "Não montado"

msgid "Unformatted"
msgstr "Não formatado"

msgid "Unknown"
msgstr "Desconhecido"

msgid "New Sirius Partition"
msgstr "Nova Partição Sirius"

msgid "EFI System Partition"
msgstr "Sistema EFI"

msgid "Sirius Root"
msgstr "Raiz do Sirius"

msgid "Swap"
msgstr "Memória Virtual"

msgid "Volumes and partitions"
msgstr "Volumes e partições"

msgid "Unallocated space"
msgstr "Espaço não alocado"

msgid "New partition pending"
msgstr "Nova partição pendente"

msgid "Edit partition"
msgstr "Editar partição"

msgid "Create partition"
msgstr "Criar partição"

msgid "Apply"
msgstr "Aplicar"

msgid "Filesystem"
msgstr "Sistema de arquivos"

msgid "Size (GiB)"
msgstr "Tamanho (GiB)"

msgid "Mount point: / or /boot/efi"
msgstr "Ponto de montagem: / ou /boot/efi"

msgid "Mount Point"
msgstr "Ponto de Montagem"

msgid "Label"
msgstr "Rótulo"

msgid "Save Changes"
msgstr "Salvar Alterações"

msgid "Disks could not be loaded"
msgstr "Não foi possível carregar os discos"

msgid "No available disks"
msgstr "Nenhum disco disponível"

msgid "Connect a disk or unmount its filesystems and reopen Sirius."
msgstr "Conecte um disco ou desmonte seus sistemas de arquivos e reabra o Sirius."

msgid "in use"
msgstr "em uso"

msgid "System compatibility"
msgstr "Compatibilidade do sistema"

msgid "Sirius checked your hardware before installing."
msgstr "O Sirius verificou seu hardware antes de instalar."

msgid "Select a disk"
msgstr "Selecione um disco"

msgid "The chosen disk will be erased."
msgstr "O disco escolhido será apagado."

msgid "No disks found"
msgstr "Nenhum disco encontrado"

msgid "Installing the system"
msgstr "Instalando o sistema"

msgid "Show install log"
msgstr "Mostrar registro da instalação"

msgid "Installation failed"
msgstr "Falha na instalação"

msgid "Something went wrong during installation. Check the log below for details. No changes were finished — you can reboot and try again."
msgstr "Algo deu errado durante a instalação. Veja o registro abaixo para detalhes. Nada foi concluído — você pode reiniciar e tentar de novo."

msgid "Installation complete"
msgstr "Instalação concluída"

msgid "The system is installed. Reboot to start using it."
msgstr "O sistema foi instalado. Reinicie para começar a usá-lo."

msgid "Restart now"
msgstr "Reiniciar agora"

msgid "Encryption passphrase"
msgstr "Frase-senha da encriptação"

msgid "Confirm passphrase"
msgstr "Confirmar frase-senha"

msgid "Passphrase must be at least 8 characters"
msgstr "A frase-senha deve ter pelo menos 8 caracteres"

msgid "Passphrases do not match"
msgstr "As frases-senha não coincidem"

msgid "Full name is required"
msgstr "O nome completo é obrigatório"

msgid "Username is required"
msgstr "O nome de usuário é obrigatório"

msgid "Username may only contain lowercase letters, digits, '_' and '-'"
msgstr "O nome de usuário só pode conter letras minúsculas, dígitos, '_' e '-'"

msgid "Username must start with a lowercase letter"
msgstr "O nome de usuário deve começar com uma letra minúscula"

msgid "Password must be at least 8 characters"
msgstr "A senha deve ter pelo menos 8 caracteres"

msgid "Passwords do not match"
msgstr "As senhas não coincidem"

msgid "Hostname is required"
msgstr "O nome do host é obrigatório"

msgid "UEFI firmware"
msgstr "Firmware UEFI"

msgid "EFI firmware detected"
msgstr "Firmware EFI detectado"

msgid "System booted in legacy BIOS mode; UEFI is required"
msgstr "Sistema iniciado em modo BIOS legado; UEFI é obrigatório"

msgid "Memory"
msgstr "Memória"

msgid "{available} GiB available (need {required} GiB)"
msgstr "{available} GiB disponíveis (necessário {required} GiB)"

msgid "{available} GiB available, {required} GiB required"
msgstr "{available} GiB disponíveis, {required} GiB necessários"

msgid "Disk space"
msgstr "Espaço em disco"

msgid "{available} GiB disk available (need {required} GiB)"
msgstr "Disco de {available} GiB disponível (necessário {required} GiB)"

msgid "No disk large enough for the install image"
msgstr "Nenhum disco grande o suficiente para a imagem de instalação"

msgid "Secure Boot"
msgstr "Secure Boot"

msgid "Secure Boot is enabled"
msgstr "Secure Boot está ativado"

msgid "disabled; recommended for a secure system"
msgstr "desativado; recomendado para um sistema seguro"

msgid "state could not be determined"
msgstr "não foi possível determinar o estado"

msgid "Virtualization"
msgstr "Virtualização"

msgid "running on bare metal"
msgstr "executando em hardware físico"

msgid "running inside a virtual machine ({kind})"
msgstr "executando dentro de uma máquina virtual ({kind})"

msgid "connected"
msgstr "conectado"

msgid "no connection; some post-install steps may be skipped"
msgstr "sem conexão; algumas etapas de pós-instalação podem ser ignoradas"

msgid "post-install: {name} ({index}/{total})"
msgstr "pós-instalação: {name} ({index}/{total})"

msgid "target disk must be an absolute /dev path: {path}"
msgstr "o disco de destino deve ser um caminho absoluto em /dev: {path}"

msgid "cannot stat target disk {path}: {error}"
msgstr "não foi possível ler o disco de destino {path}: {error}"

msgid "target disk is not a block device: {path}"
msgstr "o disco de destino não é um dispositivo de blocos: {path}"

msgid "target is not a supported whole disk: {path}"
msgstr "o destino não é um disco inteiro suportado: {path}"

msgid "target disk has mounted filesystems; unmount them before installing: {path}"
msgstr "o disco de destino tem sistemas de arquivos montados; desmonte-os antes de instalar: {path}"

msgid "failed to read install request"
msgstr "falha ao ler a solicitação de instalação"

msgid "invalid install request: {error}"
msgstr "solicitação de instalação inválida: {error}"

msgid "cannot apply partition plan: {error}"
msgstr "não foi possível aplicar o plano de partições: {error}"

msgid "install failed: {error}"
msgstr "a instalação falhou: {error}"

msgid "install thread panicked"
msgstr "a thread de instalação entrou em pânico"

msgid "authorization dialog was dismissed (pkexec exit 126)"
msgstr "o diálogo de autorização foi descartado (pkexec saída 126)"

msgid "polkit authorization failed (pkexec exit 127) — is a polkit authentication agent running in this session?"
msgstr "a autorização do polkit falhou (pkexec saída 127) — há um agente de autenticação polkit em execução nesta sessão?"

msgid "installer exited with status {code}"
msgstr "o instalador saiu com o status {code}"

msgid "installer was killed by a signal"
msgstr "o instalador foi finalizado por um sinal"
